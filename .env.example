# ─── Webhook Security ─────────────────────────────────────────────────────────
# Random secret appended to your webhook URL so only TradingView can trigger trades.
# Generate one: openssl rand -hex 16
# Your webhook URL will be: https://your-app.railway.app/webhook/WEBHOOK_SECRET
WEBHOOK_SECRET=replace_with_a_random_secret

# ─── Paper Trading ────────────────────────────────────────────────────────────
# PAPER_TRADE=true means no real orders are placed — safe for testing.
# Set to false only when you are ready to go live.
PAPER_TRADE=true
PAPER_USDT_START=1000
TRADE_SIZE_USDT=1
INTERVAL_MS=30000
CHART_SETTLE_MS=2000
STUDY_FILTER=SMC Scalper

# ─── Bitget API Credentials ───────────────────────────────────────────────────
# Required for the Bitget bridge tools (bitget_status, bitget_place_order, etc.)
# Get these from: https://www.bitget.com/account/newapi
#
# Recommended API key permissions: Spot Trade + Read  (do NOT enable Withdraw)

BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here
