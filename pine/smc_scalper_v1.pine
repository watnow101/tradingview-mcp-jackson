// ╔══════════════════════════════════════════════════════════════════╗
// ║  SMC Scalper v2.0 — Smart Money Concepts (BTC Scalping Edition)  ║
// ║  Three setups: Institutional Breakout · Liquidity Sweep          ║
// ║                Pin Bar + Inside Bar at S/D Zone                  ║
// ║  v2.0 — scalping-optimised for BTC/USD                           ║
// ║    • EMAs 13/34 — balances BTC trend detection vs whipsaw        ║
// ║    • Lower inside-bar threshold (3) for quick consolidations     ║
// ║    • Signal cooldown prevents overtrading                        ║
// ║    • Max SL cap keeps risk per trade bounded                     ║
// ║    • ATR floor suppresses signals in dead volatility             ║
// ║    • Looser Setup C pin bar window (1–3 bars back)               ║
// ║    • Session filter OFF by default — 24/7 BTC trading            ║
// ║    • Tighter S/D zone detection (sd_left=5, sd_right=2)          ║
// ╚══════════════════════════════════════════════════════════════════╝
//@version=6
indicator("SMC Scalper v2.0 - Inst / Sweep / Pin Bar (BTC Scalp)",
          shorttitle="SMCScalp-BTC",
          overlay=true,
          max_labels_count=500,
          max_lines_count=400,
          max_boxes_count=200)

// ═══════════════════════════════════════════════════════════════════
// ░░  INPUTS
// ═══════════════════════════════════════════════════════════════════

// ── General ──────────────────────────────────────────────────────
var G1 = "⚙️  General"
atr_len     = input.int(14,   "ATR Length",                          group=G1, minval=1)
inst_mult   = input.float(1.3,"Institutional Candle Min Size (×ATR)", group=G1, step=0.1, minval=0.5)
min_ibs     = input.int(3,    "Min Inside Bars for Channel",          group=G1, minval=2, maxval=10,
              tooltip="Number of consecutive inside bars required before a Setup A/B signal is valid. Lower = more signals on fast timeframes.")
cooldown    = input.int(5,    "Signal Cooldown (bars)",               group=G1, minval=0, maxval=30,
              tooltip="Minimum bars between signals. Prevents overtrading on fast timeframes.")

// ── Trend Filter ──────────────────────────────────────────────────
var G2 = "📈  Trend Filter (EMA)"
ema_f_len   = input.int(13,   "Fast EMA Length",                      group=G2, minval=5)
ema_s_len   = input.int(34,   "Slow EMA Length",                      group=G2, minval=10)
// Fix #8 — ranging suppression: if EMAs are closer than N×ATR, treat as ranging
ema_min_sep = input.float(0.3, "Min EMA Separation (×ATR) — 0 = off", group=G2, step=0.1, minval=0.0,
              tooltip="Suppresses all signals when the two EMAs are tighter than this ATR multiple (ranging market filter). Set to 0 to disable.")
show_ema    = input.bool(true,  "Show EMA Lines",                      group=G2)

// ── Supply & Demand Zones ─────────────────────────────────────────
var G3 = "🔶  Supply & Demand Zones"
show_sd     = input.bool(true,  "Show S/D Zone Boxes",                 group=G3)
sd_left     = input.int(5,      "Pivot Left Bars",                     group=G3, minval=2)
sd_right    = input.int(2,      "Pivot Right Bars",                    group=G3, minval=1)
sd_zone_w   = input.float(0.4,  "Zone Width (×ATR)",                   group=G3, step=0.05, minval=0.05)
sd_prox     = input.float(1.0,  "Zone Proximity (×ATR)",               group=G3, step=0.1, minval=0.2,
              tooltip="How close the bar high (supply) or bar low (demand) must be to a zone level to qualify Setup C.")
// Fix #10 — cap the number of live zones per side to avoid object-limit overflow
max_zones   = input.int(5,      "Max Active Zones (each side)",         group=G3, minval=1, maxval=20,
              tooltip="Oldest zones are pruned when this limit is reached. Zones are also removed when price closes cleanly through them.")

// ── Risk / Reward ─────────────────────────────────────────────────
var G_RR = "🎯  Risk / Reward"
rr_ratio    = input.float(2.0, "Take-Profit R:R Ratio",                group=G_RR, step=0.25, minval=0.5,
              tooltip="TP line is placed at SL-distance × this ratio from entry close.")
max_sl_atr  = input.float(1.5, "Max SL Distance (×ATR) — 0 = off",    group=G_RR, step=0.25, minval=0.0,
              tooltip="Clamps stop-loss distance to this ATR multiple. Signals with wider natural SL get their stop tightened. Set to 0 to disable.")
show_tp     = input.bool(true,  "Show TP Lines",                       group=G_RR)

// ── Setup C: Pin Bar ──────────────────────────────────────────────
var G4 = "📌  Setup C — Pin Bar"
pin_wick_pct  = input.float(50.0, "Min Wick % of Total Range",          group=G4, step=1.0, minval=10.0)
pin_lookback  = input.int(3,      "Pin Bar Lookback (bars)",             group=G4, minval=1, maxval=5,
                tooltip="How many bars back to search for a qualifying pin bar. Higher = more signals but less precision.")
use_vol       = input.bool(true,  "Require Above-Avg Volume on Pin Bar", group=G4)
vol_ma_len    = input.int(10,     "Volume MA Length",                    group=G4, minval=2)

// ── Session Filter ────────────────────────────────────────────────
var G6 = "🕐  Session Filter"
use_session  = input.bool(false,    "Enable Session Filter",            group=G6)
session_str  = input.session("1300-1700", "Allowed Session (Exchange TZ)", group=G6,
              tooltip="Signals are suppressed outside this window. Uses the exchange's timezone. Default is US+EU overlap (UTC) — the highest BTC volume window. Disabled by default for 24/7 BTC trading.")

// ── Display ───────────────────────────────────────────────────────
var G5 = "🎨  Display"
show_sigs     = input.bool(true,  "Show Signal Labels",                 group=G5)
show_sl       = input.bool(true,  "Show Stop-Loss Lines",               group=G5)
show_ibcnt    = input.bool(true,  "Show Inside Bar Count Label",        group=G5)
show_inst_box = input.bool(true,  "Show Institutional Candle Box",      group=G5)
col_a_b     = input.color(color.new(#00c853, 0),  "Setup A - Buy",     group=G5)
col_a_s     = input.color(color.new(#d50000, 0),  "Setup A - Sell",    group=G5)
col_b_b     = input.color(color.new(#00bcd4, 0),  "Setup B - Buy",     group=G5)
col_b_s     = input.color(color.new(#9c27b0, 0),  "Setup B - Sell",    group=G5)
col_c_b     = input.color(color.new(#8bc34a, 0),  "Setup C - Buy",     group=G5)
col_c_s     = input.color(color.new(#ff9800, 0),  "Setup C - Sell",    group=G5)
col_inst    = input.color(color.new(#2196f3, 75), "Institutional Box",  group=G5)
col_supply  = input.color(color.new(#ef5350, 82), "Supply Zone",        group=G5)
col_demand  = input.color(color.new(#26a69a, 82), "Demand Zone",        group=G5)

// ═══════════════════════════════════════════════════════════════════
// ░░  BASE INDICATORS
// ═══════════════════════════════════════════════════════════════════

atr    = ta.atr(atr_len)
ema_f  = ta.ema(close, ema_f_len)
ema_s  = ta.ema(close, ema_s_len)
vol_ma = ta.sma(volume, vol_ma_len)

// ATR floor — suppress signals when volatility has collapsed
atr_long = ta.atr(50)
atr_ok   = atr >= atr_long * 0.5

// Signal cooldown — track bars since last signal
var int last_sig_bar = 0
can_signal = cooldown == 0 or bar_index - last_sig_bar >= cooldown

// Fix #8 — flag ranging when EMAs are too close relative to ATR
ema_sep    = math.abs(ema_f - ema_s)
is_ranging = ema_min_sep > 0.0 and ema_sep < atr * ema_min_sep

uptrend   = ema_f > ema_s and not is_ranging
downtrend = ema_f < ema_s and not is_ranging

plot(show_ema ? ema_f : na, "EMA Fast", color=color.new(#2196f3, 20), linewidth=1)
plot(show_ema ? ema_s : na, "EMA Slow", color=color.new(#ff9800,  0), linewidth=2)
bgcolor(uptrend    ? color.new(color.green, 96) : na, title="Uptrend BG")
bgcolor(downtrend  ? color.new(color.red,   96) : na, title="Downtrend BG")
bgcolor(is_ranging ? color.new(color.gray,  94) : na, title="Ranging BG")
bgcolor(not atr_ok ? color.new(color.orange, 94) : na, title="Low Volatility BG")

// Fix #11 — session gate: true when inside the allowed window (or filter is off)
in_session = not use_session or not na(time(timeframe.period, session_str))

// ═══════════════════════════════════════════════════════════════════
// ░░  SUPPLY & DEMAND ZONES  (array-managed, self-cleaning)
// ═══════════════════════════════════════════════════════════════════
//
// Fix #2  — zones stored in arrays; oldest pruned when max_zones is
//           exceeded; zones invalidated when price closes through them.
// Fix #7  — proximity test uses bar HIGH vs supply, bar LOW vs demand.
// Fix #10 — corresponding box objects are deleted to stay well under
//           TradingView's max_boxes_count limit.

ph = ta.pivothigh(high, sd_left, sd_right)
pl = ta.pivotlow (low,  sd_left, sd_right)

var float[] ph_levels = array.new_float()
var box[]   ph_boxes  = array.new_box()
var float[] pl_levels = array.new_float()
var box[]   pl_boxes  = array.new_box()

// ── Helper: create a zone box (invisible when show_sd is off) ─────
_make_box(int x1, float top, float bot, color bg, color border) =>
    show_sd
      ? box.new(x1, top, x1 + 60, bot, bgcolor=bg,
                border_color=border, border_width=1, extend=extend.right)
      : box.new(x1, top, x1 + 60, bot,
                bgcolor=color.new(color.white, 100),
                border_color=color.new(color.white, 100), extend=extend.right)

// ── Add new supply zone ───────────────────────────────────────────
if not na(ph)
    float hw = atr * sd_zone_w * 0.5
    array.push(ph_levels, ph)
    array.push(ph_boxes,  _make_box(bar_index - sd_right,
                                     ph + hw, ph - hw,
                                     col_supply, color.new(color.red, 40)))
    // Prune oldest when over the cap
    if array.size(ph_levels) > max_zones
        box.delete(array.shift(ph_boxes))
        array.shift(ph_levels)

// ── Add new demand zone ───────────────────────────────────────────
if not na(pl)
    float hw = atr * sd_zone_w * 0.5
    array.push(pl_levels, pl)
    array.push(pl_boxes,  _make_box(bar_index - sd_right,
                                     pl + hw, pl - hw,
                                     col_demand, color.new(color.teal, 40)))
    if array.size(pl_levels) > max_zones
        box.delete(array.shift(pl_boxes))
        array.shift(pl_levels)

// ── Invalidate zones price has closed through (confirmed bars only) ─
if barstate.isconfirmed
    // Supply: bust when close is above the zone top
    int i = 0
    while i < array.size(ph_levels)
        float lvl = array.get(ph_levels, i)
        float top = lvl + atr * sd_zone_w * 0.5
        if close > top
            box.delete(array.get(ph_boxes, i))
            array.remove(ph_levels, i)
            array.remove(ph_boxes,  i)
        else
            i += 1

    // Demand: bust when close is below the zone bottom
    i := 0
    while i < array.size(pl_levels)
        float lvl = array.get(pl_levels, i)
        float bot = lvl - atr * sd_zone_w * 0.5
        if close < bot
            box.delete(array.get(pl_boxes, i))
            array.remove(pl_levels, i)
            array.remove(pl_boxes,  i)
        else
            i += 1

// ── Proximity: test ALL active zones (Fix #7 — high vs supply, low vs demand) ─
var bool near_supply = false
var bool near_demand = false

near_supply := false
if array.size(ph_levels) > 0
    for i = 0 to array.size(ph_levels) - 1
        if math.abs(high - array.get(ph_levels, i)) <= atr * sd_prox
            near_supply := true
            break

near_demand := false
if array.size(pl_levels) > 0
    for i = 0 to array.size(pl_levels) - 1
        if math.abs(low - array.get(pl_levels, i)) <= atr * sd_prox
            near_demand := true
            break

// ═══════════════════════════════════════════════════════════════════
// ░░  INSTITUTIONAL CANDLE  +  INSIDE BAR STATE MACHINE
// ═══════════════════════════════════════════════════════════════════
//
//  State flow:
//    IDLE → [large candle] → COUNTING (track inside bars)
//         → [>= min_ibs]  → CHANNEL FORMED
//         → breakout/sweep fires signal → IDLE
//
// NOTE: signals are computed BEFORE the state update so that they
//       capture the state as it was at the START of this bar.

c_range = high - low
is_inst = c_range >= atr * inst_mult

var float ic_hi    = na
var float ic_lo    = na
var int   ic_idx   = na
var int   ib_cnt   = 0
var bool  ib_brk   = false
var bool  ch_ready = false
var box   ic_bx    = na

// ── Step 1: compute signals from state of PREVIOUS bar ────────────
// Gated on: confirmed bar, cooldown, ATR floor, session, trend
a_buy  = barstate.isconfirmed and ch_ready and not na(ic_hi) and close > ic_hi and uptrend   and in_session and can_signal and atr_ok
a_sell = barstate.isconfirmed and ch_ready and not na(ic_lo) and close < ic_lo and downtrend and in_session and can_signal and atr_ok

// Setup B — liquidity sweep: wick outside channel, close back inside
b_buy  = barstate.isconfirmed and ch_ready and not na(ic_lo) and low  < ic_lo and close > ic_lo and uptrend   and not a_buy  and in_session and can_signal and atr_ok
b_sell = barstate.isconfirmed and ch_ready and not na(ic_hi) and high > ic_hi and close < ic_hi and downtrend and not a_sell and in_session and can_signal and atr_ok

any_signal = a_buy or a_sell or b_buy or b_sell

// ── Step 2: reset state + update cooldown when a signal fires ─────
if any_signal
    ch_ready     := false
    ib_brk       := true
    last_sig_bar := bar_index

// ── Step 3: update state machine ─────────────────────────────────
if is_inst
    // Fix #5 — only clobber an active channel if the new institutional
    //           candle is larger (a more dominant move). This avoids
    //           wiping a near-ready channel on a marginal spike.
    bool replace = na(ic_idx) or ib_brk or c_range > (ic_hi - ic_lo)
    if replace
        ic_hi    := high
        ic_lo    := low
        ic_idx   := bar_index
        ib_cnt   := 0
        ib_brk   := false
        ch_ready := false
        if show_inst_box
            ic_bx := box.new(bar_index, high, bar_index + 1, low,
                             bgcolor=col_inst,
                             border_color=color.new(#2196f3, 20), border_width=1)

else if not na(ic_idx) and not ib_brk
    if high <= ic_hi and low >= ic_lo
        ib_cnt  += 1
        ch_ready := ib_cnt >= min_ibs
        if not na(ic_bx)
            box.set_right(ic_bx, bar_index + 1)
        if show_ibcnt and ib_cnt == min_ibs
            label.new(bar_index, ic_hi + atr * 0.6,
                      str.tostring(ib_cnt) + " IBs ✓",
                      style=label.style_label_down,
                      color=color.new(#2196f3, 20),
                      textcolor=color.white,
                      size=size.tiny)
    else
        // Fix #9 — fully reset state on a non-signal channel break
        //           (previously only ib_brk was set, leaving ch_ready=true)
        if not any_signal
            ib_brk   := true
            ch_ready := false
            ib_cnt   := 0

// ═══════════════════════════════════════════════════════════════════
// ░░  SETUP C — PIN BAR + INSIDE BAR AT S/D ZONE
// ═══════════════════════════════════════════════════════════════════

bar_rng  = high - low
up_wick  = high - math.max(open, close)
dn_wick  = math.min(open, close) - low
body_sz  = math.abs(close - open)

dn_wick_pct = bar_rng > 0 ? dn_wick / bar_rng * 100 : 0.0
up_wick_pct = bar_rng > 0 ? up_wick / bar_rng * 100 : 0.0

bull_pin = dn_wick_pct >= pin_wick_pct and dn_wick > body_sz
bear_pin = up_wick_pct >= pin_wick_pct and up_wick > body_sz

is_inside = high <= high[1] and low >= low[1]
vol_ok    = not use_vol or volume[1] > vol_ma[1]

// Looser pin bar window: search up to pin_lookback bars back
recent_bull_pin = false
recent_bear_pin = false
recent_near_demand = false
recent_near_supply = false
for lb = 1 to pin_lookback
    if bull_pin[lb]
        recent_bull_pin := true
    if bear_pin[lb]
        recent_bear_pin := true
    if near_demand[lb]
        recent_near_demand := true
    if near_supply[lb]
        recent_near_supply := true

// Gated on: confirmed bar, cooldown, ATR floor, session, trend
c_buy  = barstate.isconfirmed and is_inside and recent_bull_pin and recent_near_demand and uptrend   and vol_ok and in_session and can_signal and atr_ok
c_sell = barstate.isconfirmed and is_inside and recent_bear_pin and recent_near_supply and downtrend and vol_ok and in_session and can_signal and atr_ok

// Update cooldown for Setup C signals
if c_buy or c_sell
    last_sig_bar := bar_index

// ═══════════════════════════════════════════════════════════════════
// ░░  SIGNAL LABELS, SL & TP LINES
// ═══════════════════════════════════════════════════════════════════
//
// Fix #1  — TP lines drawn at entry ± sl_dist × rr_ratio
// Fix #4  — Setup B SL widened from 0.2×ATR to 0.5×ATR (below/above wick)

off = atr * 1.3

// Helper: clamp SL distance to max_sl_atr if enabled
_clamp_sl(float raw_dist) =>
    max_sl_atr > 0.0 ? math.min(raw_dist, atr * max_sl_atr) : raw_dist

if show_sigs
    // ── Setup A — Institutional Breakout ─────────────────────────
    if a_buy
        label.new(bar_index, low - off,
                  "A ▲  Breakout Buy",
                  style=label.style_label_up,
                  color=color.new(col_a_b, 5), textcolor=color.white, size=size.small)
        if show_sl
            float sl_dist = _clamp_sl(close - ic_lo)
            float sl      = close - sl_dist
            line.new(bar_index, sl, bar_index + 15, sl,
                     color=color.new(color.red, 20), style=line.style_dashed, width=1)
            if show_tp
                float tp = close + sl_dist * rr_ratio
                line.new(bar_index, tp, bar_index + 15, tp,
                         color=color.new(color.green, 20), style=line.style_dashed, width=2)

    if a_sell
        label.new(bar_index, high + off,
                  "A ▼  Breakout Sell",
                  style=label.style_label_down,
                  color=color.new(col_a_s, 5), textcolor=color.white, size=size.small)
        if show_sl
            float sl_dist = _clamp_sl(ic_hi - close)
            float sl      = close + sl_dist
            line.new(bar_index, sl, bar_index + 15, sl,
                     color=color.new(color.green, 20), style=line.style_dashed, width=1)
            if show_tp
                float tp = close - sl_dist * rr_ratio
                line.new(bar_index, tp, bar_index + 15, tp,
                         color=color.new(color.red, 20), style=line.style_dashed, width=2)

    // ── Setup B — Liquidity Sweep ─────────────────────────────────
    if b_buy
        label.new(bar_index, low - off,
                  "B ▲  Sweep Buy",
                  style=label.style_label_up,
                  color=color.new(col_b_b, 5), textcolor=color.white, size=size.small)
        if show_sl
            float sl_dist = _clamp_sl(close - (low - atr * 0.5))
            float sl      = close - sl_dist
            line.new(bar_index, sl, bar_index + 15, sl,
                     color=color.new(color.red, 20), style=line.style_dashed, width=1)
            if show_tp
                float tp = close + sl_dist * rr_ratio
                line.new(bar_index, tp, bar_index + 15, tp,
                         color=color.new(color.green, 20), style=line.style_dashed, width=2)

    if b_sell
        label.new(bar_index, high + off,
                  "B ▼  Sweep Sell",
                  style=label.style_label_down,
                  color=color.new(col_b_s, 5), textcolor=color.white, size=size.small)
        if show_sl
            float sl_dist = _clamp_sl((high + atr * 0.5) - close)
            float sl      = close + sl_dist
            line.new(bar_index, sl, bar_index + 15, sl,
                     color=color.new(color.green, 20), style=line.style_dashed, width=1)
            if show_tp
                float tp = close - sl_dist * rr_ratio
                line.new(bar_index, tp, bar_index + 15, tp,
                         color=color.new(color.red, 20), style=line.style_dashed, width=2)

    // ── Setup C — Pin Bar at S/D Zone ─────────────────────────────
    if c_buy
        label.new(bar_index, low - off,
                  "C ▲  Pin Buy",
                  style=label.style_label_up,
                  color=color.new(col_c_b, 5), textcolor=color.white, size=size.small)
        if show_sl
            float sl_dist = _clamp_sl(close - low[1])
            float sl      = close - sl_dist
            line.new(bar_index, sl, bar_index + 15, sl,
                     color=color.new(color.red, 20), style=line.style_dashed, width=1)
            if show_tp
                float tp = close + sl_dist * rr_ratio
                line.new(bar_index, tp, bar_index + 15, tp,
                         color=color.new(color.green, 20), style=line.style_dashed, width=2)

    if c_sell
        label.new(bar_index, high + off,
                  "C ▼  Pin Sell",
                  style=label.style_label_down,
                  color=color.new(col_c_s, 5), textcolor=color.white, size=size.small)
        if show_sl
            float sl_dist = _clamp_sl(high[1] - close)
            float sl      = close + sl_dist
            line.new(bar_index, sl, bar_index + 15, sl,
                     color=color.new(color.green, 20), style=line.style_dashed, width=1)
            if show_tp
                float tp = close - sl_dist * rr_ratio
                line.new(bar_index, tp, bar_index + 15, tp,
                         color=color.new(color.red, 20), style=line.style_dashed, width=2)

// ═══════════════════════════════════════════════════════════════════
// ░░  ALERTS
// ═══════════════════════════════════════════════════════════════════

// ── Individual alerts (for monitoring / notifications) ────────────

// Inside bar channel formed (informational — not a trade signal)
alertcondition(ib_cnt == min_ibs,
               title="Inside Bar Channel Formed",
               message="{{ticker}} {{interval}} — Inside bar channel formed. Breakout imminent.")

// Setup A
alertcondition(a_buy,
               title="[A] Breakout Buy",
               message='{"signal":"buy","symbol":"{{ticker}}","price":{{close}},"setup":"A"}')
alertcondition(a_sell,
               title="[A] Breakout Sell",
               message='{"signal":"sell","symbol":"{{ticker}}","price":{{close}},"setup":"A"}')

// Setup B
alertcondition(b_buy,
               title="[B] Sweep Buy",
               message='{"signal":"buy","symbol":"{{ticker}}","price":{{close}},"setup":"B"}')
alertcondition(b_sell,
               title="[B] Sweep Sell",
               message='{"signal":"sell","symbol":"{{ticker}}","price":{{close}},"setup":"B"}')

// Setup C
alertcondition(c_buy,
               title="[C] Pin Bar Buy",
               message='{"signal":"buy","symbol":"{{ticker}}","price":{{close}},"setup":"C"}')
alertcondition(c_sell,
               title="[C] Pin Bar Sell",
               message='{"signal":"sell","symbol":"{{ticker}}","price":{{close}},"setup":"C"}')

// ── Combined alerts (recommended for webhook trading) ─────────────
// Use these two — they catch all three setups in one alert each.
alertcondition(a_buy  or b_buy  or c_buy,  title="⚡ Any Buy Signal",
               message='{"signal":"buy","symbol":"{{ticker}}","price":{{close}},"setup":"ABC"}')
alertcondition(a_sell or b_sell or c_sell, title="⚡ Any Sell Signal",
               message='{"signal":"sell","symbol":"{{ticker}}","price":{{close}},"setup":"ABC"}')
